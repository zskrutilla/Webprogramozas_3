<h1>Product Catalog</h1>

<form action="/Products/Add" method="post">
    <div>
        <label for="Name">Product name:</label>
        <input type="text" id="Name" name="Name" />
    </div>

    <div>
        <label for="Category">Category:</label>
        <input type="text" id="Category" name="Category" />
    </div>

    <div>
        <label for="Price">Price:</label>
        <input type="number" id="Price" name="Price" step="0.01" />
    </div>

    <button type="submit">Add Product</button>
</form>

<hr />

<p>
    <a href="/Products/List">View all products</a>
</p>

<p>Filter by category:</p>
<ul>
    <li><a href="/Products/ByCategory?category=Electronics">Electronics</a></li>
    <li><a href="/Products/ByCategory?category=Food">Food</a></li>
    <li><a href="/Products/ByCategory?category=Office">Office</a></li>
    <li><a href="/Products/ByCategory?category=Books">Books</a></li>
</ul>